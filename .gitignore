# =====================
#  Python
# =====================

# Byte-compiled / cache files — Python creates these automatically, no need to track them
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# =====================
#  Virtual Environment
# =====================

# If you created a venv inside the project folder, exclude it
venv/
env/
.env/
.venv/
ENV/

# =====================
#  Environment Variables
# =====================

# Never commit secrets, API keys, or passwords
.env
.env.local
.env.production
*.env

# =====================
#  Jupyter Notebooks
# =====================

# Notebook checkpoints are auto-saved temp files
.ipynb_checkpoints/
*.ipynb_checkpoints

# =====================
#  Data Files
# =====================

# Uncomment the line below if your dataset is large or sensitive
# and you don't want it on GitHub
# data/*.csv

# But we DO want to keep our loan dataset tracked, so leaving it commented.
# If you later add large raw data files, add them here.

# =====================
#  Trained Model Files
# =====================

# These are auto-generated by train_model.py — no need to commit them.
# Anyone who clones the repo can regenerate them by running train_model.py
models/*.pkl

# =====================
#  EDA / Plot Images
# =====================

# Also auto-generated during training — skip these too
static/plots/*.png
static/plots/*.jpg

# =====================
#  IDE & Editor Files
# =====================

# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim swap files
*.swp
*.swo

# =====================
#  OS System Files
# =====================

# Mac
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# =====================
#  Logs & Temp Files
# =====================

*.log
*.tmp
*.temp
*.bak
*.orig

# Flask session files (if you add sessions later)
flask_session/

# =====================
#  Testing
# =====================

# pytest cache
.pytest_cache/
.coverage
htmlcov/

# =====================
#  Misc
# =====================

# Zip files — don't accidentally commit your export archive
*.zip
*.tar.gz
*.rar
